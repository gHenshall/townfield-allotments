---
import Layout from "../layouts/Layout.astro";

const newsItems = [
  {
    id: 1,
    date: "July 2024",
    title: "Summer Growing Season in Full Swing",
    excerpt:
      "Our plotholders are making the most of the summer months with vibrant growth across the site. Tomatoes, courgettes, and beans are thriving!",
    content:
      "The summer months have been exceptionally productive at Townfield Allotments. Despite the usual challenges of managing watering during dry spells, our community has pulled together to ensure all plots are flourishing. Many plotholders are already planning their autumn crops and sharing seeds with the community.",
    author: "AFTA Team",
  },
  {
    id: 2,
    date: "June 2024",
    title: "Community Workday - Site Improvements",
    excerpt:
      "Huge thanks to all volunteers who helped with path maintenance and fence repairs. The site looks fantastic!",
    content:
      "Last month's community workday was a great success! Over 30 plotholders turned out to help with various site improvements. We completed path repairs, fence maintenance, and cleared communal areas. It's these efforts that make Townfield such a special place.",
    author: "AFTA Committee",
  },
  {
    id: 3,
    date: "May 2024",
    title: "Welcome to Our New Plotholders",
    excerpt:
      "This spring we're delighted to welcome 8 new families to the Townfield community. Get to know them at our upcoming social event!",
    content:
      "We're thrilled to welcome a diverse group of new plotholders to our community this spring. From first-time gardeners to experienced growers looking for a new space, they bring fresh energy and ideas to the site. Join us at our next social event to welcome them properly!",
    author: "AFTA Team",
  },
  {
    id: 4,
    date: "April 2024",
    title: "Spring Planting Guide - Expert Tips",
    excerpt:
      "Thinking about what to plant this spring? Our expert plotholders share their top recommendations for April and May planting.",
    content:
      "Spring is the perfect time to plant outdoors! Beans, peas, lettuce, and courgettes are ideal for planting now. Several of our experienced plotholders have shared their top tips for getting the best results. Check our resources page for their detailed guides.",
    author: "Sarah, Senior Plotholder",
  },
  {
    id: 5,
    date: "March 2024",
    title: "New Water System Installation Complete",
    excerpt:
      "Exciting news! We've completed the installation of an improved water system with new access points across the site.",
    content:
      "AFTA has successfully completed the installation of an improved water distribution system. This project brings multiple new water points closer to the plots, making it easier for plotholders to water their vegetables and keep their chickens hydrated during warm months.",
    author: "AFTA Committee",
  },
  {
    id: 6,
    date: "February 2024",
    title: "Plot Availability - Spring Lettings Open",
    excerpt:
      "Spring lettings are now open! We have availability for both half and full plots. Apply now for the growing season.",
    content:
      "We're pleased to announce that spring lettings are now open at Townfield Allotments. We currently have several plots available for the upcoming growing season. Whether you're a first-time gardener or an experienced grower, now is a great time to join our community. Get in touch to arrange a site visit!",
    author: "AFTA Lettings Team",
  },
];
---

<Layout
  title="News"
  description="Latest news and updates from Townfield Allotments"
>
  <style>
    .news-section {
      background-color: var(--white);
    }

    .news-header {
      text-align: center;
      margin-bottom: 3rem;
    }

    .news-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 2rem;
      margin-top: 2rem;
      margin-bottom: 3rem;
    }

    .news-card {
      background-color: var(--white);
      border-radius: var(--border-radius);
      overflow: hidden;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
      transition: var(--transition);
      border: 2px solid transparent;
      display: flex;
      flex-direction: column;
    }

    .news-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
      border-color: var(--accent);
    }

    .news-card-header {
      background: linear-gradient(135deg, var(--primary-light), var(--primary));
      color: var(--white);
      padding: 2rem;
      flex-grow: 1;
    }

    .news-date {
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 0.5rem;
      opacity: 0.9;
      font-weight: 600;
    }

    .news-card h3 {
      color: var(--white);
      font-size: 1.4rem;
      line-height: 1.4;
      margin-bottom: 1rem;
    }

    .news-card p {
      color: rgba(255, 255, 255, 0.95);
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .news-card-footer {
      padding: 1.5rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 1px solid var(--bg-light);
    }

    .news-author {
      font-size: 0.85rem;
      color: var(--text-light);
      font-weight: 500;
    }

    .news-link {
      color: var(--accent);
      text-decoration: none;
      font-weight: 600;
      transition: var(--transition);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .news-link:hover {
      color: var(--accent-light);
      gap: 0.8rem;
    }

    .featured-news {
      background: linear-gradient(135deg, var(--primary-light), var(--primary));
      color: var(--white);
      padding: 3rem;
      border-radius: var(--border-radius);
      margin-bottom: 3rem;
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 2rem;
      align-items: center;
    }

    .featured-news h2 {
      color: var(--white);
      margin-bottom: 1rem;
    }

    .featured-news h2::after {
      background-color: var(--accent);
    }

    .featured-date {
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 0.5rem;
      opacity: 0.9;
      font-weight: 600;
    }

    .featured-news p {
      color: rgba(255, 255, 255, 0.95);
      font-size: 1.05rem;
      line-height: 1.8;
      margin-bottom: 1.5rem;
    }

    .featured-icon {
      font-size: 5rem;
      text-align: center;
      opacity: 0.8;
    }

    .newsletter-section {
      background-color: var(--bg-light);
      padding: 2rem;
      border-radius: var(--border-radius);
      text-align: center;
      margin-bottom: 3rem;
    }

    .newsletter-section h3 {
      color: var(--primary);
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
      margin-top: 0;
    }

    .newsletter-section p {
      color: var(--text-light);
      margin-bottom: 1.5rem;
    }

    .newsletter-form {
      display: flex;
      gap: 0.5rem;
      max-width: 400px;
      margin: 0 auto;
    }

    .newsletter-form input {
      flex: 1;
      padding: 0.8rem;
      border: 2px solid var(--primary);
      border-radius: 6px;
      font-size: 1rem;
      font-family: inherit;
    }

    .newsletter-form input:focus {
      outline: none;
      border-color: var(--accent);
      background-color: var(--white);
    }

    .newsletter-form button {
      padding: 0.8rem 1.5rem;
      background-color: var(--accent);
      color: var(--primary);
      border: none;
      border-radius: 6px;
      font-weight: 600;
      cursor: pointer;
      transition: var(--transition);
    }

    .newsletter-form button:hover {
      background-color: var(--accent-light);
    }

    .categories {
      display: flex;
      gap: 1rem;
      margin-bottom: 2rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .category-btn {
      padding: 0.5rem 1.2rem;
      border: 2px solid var(--primary);
      color: var(--primary);
      background-color: var(--white);
      border-radius: 20px;
      cursor: pointer;
      font-weight: 600;
      transition: var(--transition);
    }

    .category-btn:hover,
    .category-btn.active {
      background-color: var(--primary);
      color: var(--white);
    }

    @media (max-width: 768px) {
      .news-grid {
        grid-template-columns: 1fr;
      }

      .featured-news {
        grid-template-columns: 1fr;
      }

      .newsletter-form {
        flex-direction: column;
      }

      .featured-icon {
        display: none;
      }
    }
  </style>

  <!-- Page Header -->
  <section class="news-section">
    <div class="container">
      <h2>News & Updates</h2>
      <p class="section-subtitle">
        Stay informed about what's happening at Townfield Allotments
      </p>
    </div>
  </section>

  <!-- Newsletter Section -->
  <section class="news-section">
    <div class="container">
      <div class="newsletter-section">
        <h3>📧 Stay Updated</h3>
        <p>
          Subscribe to our newsletter for the latest news, growing tips, and
          community events
        </p>
        <form
          class="newsletter-form"
          onsubmit="alert('Thank you for subscribing!'); event.preventDefault();"
        >
          <input type="email" placeholder="Enter your email" required />
          <button type="submit">Subscribe</button>
        </form>
      </div>
    </div>
  </section>

  <!-- Featured News -->
  <section class="news-section">
    <div class="container">
      {
        newsItems[0] && (
          <div class="featured-news">
            <div>
              <div class="featured-date">{newsItems[0].date}</div>
              <h2>{newsItems[0].title}</h2>
              <p>{newsItems[0].content}</p>
              <p style="font-size: 0.9rem; opacity: 0.8;">
                By {newsItems[0].author}
              </p>
            </div>
            <div class="featured-icon">📰</div>
          </div>
        )
      }
    </div>
  </section>

  <!-- All News -->
  <section class="news-section">
    <div class="container">
      <h3
        style="color: var(--primary); font-size: 1.8rem; margin-bottom: 1.5rem;"
      >
        Recent News
      </h3>

      <div class="news-grid">
        {
          newsItems.map((item) => (
            <div class="news-card">
              <div class="news-card-header">
                <div class="news-date">{item.date}</div>
                <h3>{item.title}</h3>
                <p>{item.excerpt}</p>
              </div>
              <div class="news-card-footer">
                <span class="news-author">By {item.author}</span>
                <a href={`#news-${item.id}`} class="news-link">
                  Read More
                  <span>→</span>
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <script>
    // Newsletter form handling
    document
      .querySelector(".newsletter-form")
      .addEventListener("submit", function (e) {
        e.preventDefault();
        alert("Thank you for subscribing to our newsletter!");
        this.reset();
      });
  </script>
</Layout>
