---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Location" description="Find Townfield Allotments in Frodsham - directions and parking info">
  <style>
    .location-section {
      background-color: var(--white);
    }

    .location-header {
      text-align: center;
      margin-bottom: 3rem;
    }

    .location-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: start;
      margin-top: 2rem;
      margin-bottom: 3rem;
    }

    .location-info h3 {
      color: var(--primary);
      font-size: 1.5rem;
      margin-bottom: 1rem;
      margin-top: 2rem;
    }

    .location-info h3:first-child {
      margin-top: 0;
    }

    .location-info p {
      color: var(--text-light);
      line-height: 1.8;
      margin-bottom: 1rem;
    }

    .address-box {
      background: linear-gradient(135deg, var(--primary-light), var(--primary));
      color: var(--white);
      padding: 2rem;
      border-radius: var(--border-radius);
      margin-bottom: 2rem;
    }

    .address-box h4 {
      font-size: 1.1rem;
      margin-bottom: 1rem;
      font-weight: 600;
    }

    .address-box p {
      color: var(--white);
      margin-bottom: 0.5rem;
      font-size: 1.05rem;
    }

    .address-box strong {
      color: var(--accent);
    }

    .map-placeholder {
      background: linear-gradient(135deg, var(--bg-light), var(--white));
      border-radius: var(--border-radius);
      padding: 2rem;
      text-align: center;
      color: var(--text-light);
      min-height: 400px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 2px solid var(--bg-light);
      font-size: 1.1rem;
    }

    .map-icon {
      font-size: 4rem;
      margin-bottom: 1rem;
    }

    .directions-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
      margin-top: 2rem;
      margin-bottom: 3rem;
    }

    .direction-card {
      background-color: var(--bg-light);
      padding: 2rem;
      border-radius: var(--border-radius);
      border-left: 4px solid var(--accent);
    }

    .direction-card h4 {
      color: var(--primary);
      font-size: 1.2rem;
      margin-bottom: 1rem;
    }

    .direction-card p {
      color: var(--text-light);
      line-height: 1.7;
      font-size: 0.95rem;
    }

    .direction-card strong {
      color: var(--primary);
    }

    .parking-info {
      background-color: var(--bg-light);
      padding: 2rem;
      border-radius: var(--border-radius);
      margin-bottom: 3rem;
    }

    .parking-info h3 {
      color: var(--primary);
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
      margin-top: 0;
    }

    .parking-item {
      margin-bottom: 1.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--white);
    }

    .parking-item:last-child {
      margin-bottom: 0;
      padding-bottom: 0;
      border-bottom: none;
    }

    .parking-item h4 {
      color: var(--accent);
      font-weight: 600;
      margin-bottom: 0.5rem;
    }

    .parking-item p {
      color: var(--text-light);
      font-size: 0.95rem;
    }

    .features-nearby {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.5rem;
      margin-top: 2rem;
    }

    .nearby-item {
      background-color: var(--white);
      padding: 1.5rem;
      border-radius: var(--border-radius);
      text-align: center;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .nearby-item-icon {
      font-size: 2rem;
      margin-bottom: 0.5rem;
    }

    .nearby-item h4 {
      color: var(--primary);
      font-size: 1rem;
      margin-bottom: 0.3rem;
    }

    .nearby-item p {
      color: var(--text-light);
      font-size: 0.85rem;
    }

    .accessibility-section {
      background: linear-gradient(135deg, var(--primary-light), var(--primary));
      color: var(--white);
      padding: 2rem;
      border-radius: var(--border-radius);
      margin-bottom: 3rem;
    }

    .accessibility-section h3 {
      color: var(--accent);
      font-size: 1.5rem;
      margin-bottom: 1rem;
      margin-top: 0;
    }

    .accessibility-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 2rem;
      margin-top: 1rem;
    }

    .accessibility-item {
      padding: 1rem;
    }

    .accessibility-item h4 {
      color: var(--accent);
      margin-bottom: 0.5rem;
      font-weight: 600;
    }

    .accessibility-item p {
      color: rgba(255, 255, 255, 0.95);
      font-size: 0.95rem;
    }

    .visit-section {
      background-color: var(--bg-light);
      padding: 2rem;
      border-radius: var(--border-radius);
      text-align: center;
    }

    .visit-section h3 {
      color: var(--primary);
      font-size: 1.5rem;
      margin-bottom: 1rem;
      margin-top: 0;
    }

    .visit-section p {
      color: var(--text-light);
      margin-bottom: 1.5rem;
      font-size: 1.05rem;
    }

    @media (max-width: 768px) {
      .location-content {
        grid-template-columns: 1fr;
      }

      .map-placeholder {
        min-height: 300px;
      }

      .directions-grid {
        grid-template-columns: 1fr;
      }

      .accessibility-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <!-- Page Header -->
  <section class="location-section">
    <div class="container">
      <h2>Find Us</h2>
      <p class="section-subtitle">Easy to reach, easy to find – visit Townfield Allotments today</p>
    </div>
  </section>

  <!-- Location Main -->
  <section class="location-section">
    <div class="container">
      <div class="location-content">
        <div class="location-info">
          <div class="address-box">
            <h4>📍 Our Address</h4>
            <p>
              <strong>Townfield Allotments</strong><br>
              Top of Langdale Way<br>
              Junction with Town-field Lane<br>
              <strong>Frodsham WA6 7LX</strong><br>
              United Kingdom
            </p>
          </div>

          <h3>Easy Access</h3>
          <p>Our site is easily accessible via the junction of Langdale Way and Town-field Lane. The allotments sit in a beautiful open field at the top of Langdale Way, making them a welcoming space for everyone in the community.</p>

          <h3>Open 24/7</h3>
          <p>The site is accessible around the clock, so you can visit your plot whenever it suits your schedule – early mornings, lunch breaks, weekends, or whenever you have free time. Many of our plotholders love visiting at different times of day to enjoy the changing light and seasons.</p>

          <h3>Visit Anytime</h3>
          <p>The site is open 24/7, so you can visit whenever it works for you. No appointment needed – just head to the address above!</p>
        </div>

        <div class="map-placeholder">
          <div>
            <div class="map-icon">🗺️</div>
            <p>Map Coming Soon</p>
            <p style="font-size: 0.85rem; opacity: 0.7; margin-top: 1rem;">In the meantime, use the address above with Google Maps, Apple Maps, or your preferred navigation app</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Directions -->
  <section class="location-section">
    <div class="container">
      <h3 style="color: var(--primary); font-size: 1.8rem; margin-bottom: 1.5rem;">How to Get There</h3>
      
      <div class="directions-grid">
        <div class="direction-card">
          <h4>🚗 By Car</h4>
          <p>Head to the junction of <strong>Langdale Way and Town-field Lane</strong> in Frodsham. The allotments are located in the field at the top of Langdale Way. Use postcode <strong>WA6 7LX</strong> in your GPS or satnav.</p>
        </div>

        <div class="direction-card">
          <h4>🚌 By Bus</h4>
          <p>Local bus services run through Frodsham. Check your local transport provider for routes to the Langdale Way area. From the nearest bus stop, it's a short walk to the allotments.</p>
        </div>

        <div class="direction-card">
          <h4>🚴 By Bike</h4>
          <p>The allotments are easily accessible by bicycle. Frodsham's flat terrain makes for pleasant cycling, and parking a bike at the site is no problem. Many of our plotholders cycle to their plots.</p>
        </div>

        <div class="direction-card">
          <h4>🚶 On Foot</h4>
          <p>If you're in the Frodsham area, the site is walkable from various parts of town. The location is clearly signed, and our friendly community can always point you in the right direction!</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Parking -->
  <section class="location-section">
    <div class="container">
      <div class="parking-info">
        <h3>Parking</h3>
        
        <div class="parking-item">
          <h4>Car Parking</h4>
          <p>Parking is available near the site entrance. We ask that all visitors park considerately to ensure access for emergency vehicles and maintain good relationships with neighboring properties.</p>
        </div>

        <div class="parking-item">
          <h4>Bike Parking</h4>
          <p>Secure bike parking is available on site. Many of our plotholders find cycling a convenient and eco-friendly way to access their plots.</p>
        </div>

        <div class="parking-item">
          <h4>Motorcycle Parking</h4>
          <p>Motorcycles and scooters are welcome. Please park in the designated areas to keep pathways clear and safe for all users.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Nearby -->
  <section class="location-section">
    <div class="container">
      <h3 style="color: var(--primary); font-size: 1.8rem; margin-bottom: 1.5rem;">What's Nearby</h3>
      
      <div class="features-nearby">
        <div class="nearby-item">
          <div class="nearby-item-icon">🛒</div>
          <h4>Local Shops</h4>
          <p>Frodsham town center with shops, cafes, and services nearby</p>
        </div>

        <div class="nearby-item">
          <div class="nearby-item-icon">☕</div>
          <h4>Cafes & Restaurants</h4>
          <p>Enjoy refreshments before or after your plot visit</p>
        </div>

        <div class="nearby-item">
          <div class="nearby-item-icon">🌳</div>
          <h4>Green Spaces</h4>
          <p>Beautiful countryside and parks within easy reach</p>
        </div>

        <div class="nearby-item">
          <div class="nearby-item-icon">🏥</div>
          <h4>Medical Services</h4>
          <p>Local health facilities and emergency services nearby</p>
        </div>

        <div class="nearby-item">
          <div class="nearby-item-icon">📚</div>
          <h4>Library & Schools</h4>
          <p>Community facilities and educational resources close by</p>
        </div>

        <div class="nearby-item">
          <div class="nearby-item-icon">🚂</div>
          <h4>Transport Links</h4>
          <p>Frodsham railway station and road connections</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Accessibility -->
  <section class="location-section">
    <div class="container">
      <div class="accessibility-section">
        <h3>Accessibility</h3>
        <p>We're committed to making Townfield Allotments accessible to everyone. Here's what we offer:</p>
        
        <div class="accessibility-grid">
          <div class="accessibility-item">
            <h4>Flat Terrain</h4>
            <p>The site is relatively flat, making it accessible for those with mobility challenges</p>
          </div>

          <div class="accessibility-item">
            <h4>Clear Paths</h4>
            <p>Well-maintained pathways throughout the site for easy navigation</p>
          </div>

          <div class="accessibility-item">
            <h4>Designated Parking</h4>
            <p>Close parking available for those who need it. Please contact us about accessibility needs</p>
          </div>

          <div class="accessibility-item">
            <h4>24/7 Access</h4>
            <p>Visit at times that work best for you and your schedule</p>
          </div>

          <div class="accessibility-item">
            <h4>Site Support</h4>
            <p>Our community is supportive – tell us about any accessibility requirements</p>
          </div>

          <div class="accessibility-item">
            <h4>Water Access</h4>
            <p>Water points are strategically located across the site for convenience</p>
          </div>
        </div>
      </div>
    </div>
  </section>


</Layout>
