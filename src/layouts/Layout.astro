---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Growing together" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:wght@400;600;700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="header">
      <div class="container">
        <div class="logo">🌱 Allotment</div>
        <nav class="nav">
          <a href="/">Home</a>
          <a href="/#about">About</a>
          <a href="/#plots">Our Plots</a>
          <a href="/news">News</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container">
        <div class="footer-content">
          <div class="footer-section">
            <h4>Allotment</h4>
            <p>Growing together, one plot at a time.</p>
          </div>
          <div class="footer-section">
            <h4>Contact</h4>
            <p>
              📧 hello@allotment.local<br />
              📍 Local Community Gardens
            </p>
          </div>
          <div class="footer-section">
            <h4>Hours</h4>
            <p>
              Spring-Summer: Daily<br />
              Autumn-Winter: Weekends<br />
              See you in the garden!
            </p>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; 2024 Community Allotment. All things grow in their time.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
